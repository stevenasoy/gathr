SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
# Public anon key — required. isConfigured gates every route on this being set;
# without it the API returns 503 'API not configured.' on every request.
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# JWT secret from Supabase Dashboard > Project Settings > API > JWT Settings.
# Used to verify Bearer tokens locally instead of a network hop on every request.
SUPABASE_JWT_SECRET=your-jwt-secret
PORT=3001
# Comma-separated allowlist of origins permitted to call the API (no wildcard).
# Example: https://gathr.example.com,http://localhost:5173
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development
